---
import "../styles/global.css";
import { getEntry } from "astro:content";
import { Menu, X } from "@lucide/astro";
import ThemeToggle from "../components/navigation/ThemeToggle.astro";
import ChessIcons from "../components/navigation/ChessIcons.astro";
import Logo from "../components/primitives/Logo.astro";
import DividerChessboard from "../components/primitives/DividerChessboard.astro";
import knightMarker from "../assets/chess-nav/knight.svg?raw";
import navIndicator from "../assets/chess-icons/correct.svg?raw";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: URL;
  type?: "website" | "article";
}

// Fetch site-wide configuration singletons
const siteEntry = await getEntry("site", "site-config");
const navEntry = await getEntry("navigation", "navigation-config");

const siteConfig = siteEntry?.data;
const navLinks = navEntry?.data?.links ?? [];

const {
  title,
  description = siteConfig?.description ??
    "Architecture, design, and engineering handbook of Sam Ananias.",
  image = siteConfig?.defaultImage ?? "/og-default.png",
  canonicalURL = new URL(Astro.url.pathname, siteConfig?.canonicalURL ?? Astro.url.origin),
  type = "website",
} = Astro.props;

// Determine tab title using template
const formattedTitle = title
  ? siteConfig?.titleTemplate
    ? siteConfig.titleTemplate.replace("%s", title)
    : `${title} | Sam Ananias`
  : (siteConfig?.name ?? "Sam Ananias");

const currentPath = Astro.url.pathname;
const isCurrent = (href: string) => {
  if (href === "/") {
    return currentPath === "/";
  }
  // Strip trailing slashes to avoid mismatches
  const cleanPath =
    currentPath.endsWith("/") && currentPath.length > 1 ? currentPath.slice(0, -1) : currentPath;
  const cleanHref = href.endsWith("/") && href.length > 1 ? href.slice(0, -1) : href;
  return cleanPath === cleanHref || cleanPath.startsWith(cleanHref + "/");
};

// Navigation helpers for the woodcut sidebar (WoodcutTheme.md §5)
const visibleLinks = navLinks.filter((link) => link.visibility !== false);
const linkByHref = new Map(visibleLinks.map((link) => [link.href, link]));

// Chess piece icon per content section (WoodcutTheme.md §5.3)
const pieceByHref: Record<string, "king" | "knight" | "rook" | "bishop" | "pawn" | "queen"> = {
  "/": "king",
  "/projects": "knight",
  "/experience": "rook",
  "/research": "bishop",
  "/posts": "pawn",
  "/experiments": "queen",
};

// Sidebar link groups separated by hatch rules (WoodcutTheme.md §5.1 / §5.4)
const groupHrefs = [
  ["/", "/projects", "/experience", "/research"],
  ["/posts", "/experiments"],
  ["/about", "/contact", "/search"],
];

const groupLabels = ["WORK", "WRITING", "META"];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <!-- Core Meta Tags -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>{formattedTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={formattedTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url.origin)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={formattedTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url.origin)} />

    <!-- Inline Dark Mode Script to Prevent Flash of Unstyled Content (FOUC) -->
    <script is:inline>
      const getThemePreference = () => {
        if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
          return localStorage.getItem("theme");
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
      };

      const theme = getThemePreference();

      if (theme === "dark") {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }

      if (typeof localStorage !== "undefined") {
        const observer = new MutationObserver(() => {
          const isDark = document.documentElement.classList.contains("dark");
          localStorage.setItem("theme", isDark ? "dark" : "light");
        });
        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });
      }
    </script>
  </head>
  <body
    class="bg-bg text-text selection:bg-accent selection:text-text duration-normal ease-standard chess-grid font-sans antialiased transition-colors"
  >
    <!-- Accessible Skip Link -->
    <a
      href="#main-content"
      class="bg-primary focus:outline-focus sr-only rounded-md px-4 py-2 text-white focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[70] focus:outline focus:outline-2 focus:outline-offset-2"
    >
      Skip to content
    </a>

    <!-- Mobile Top Bar (< lg) -->
    <div class="border-border-custom bg-surface border-b-structural sticky top-0 z-50 lg:hidden">
      <div class="flex h-[52px] items-center justify-between px-4">
        <a
          href="/"
          class="font-display hover:text-primary duration-fast flex items-center gap-2.5 font-bold transition-colors"
        >
          <Logo class="size-7" />
          <span class="text-sm">{siteConfig?.name ?? "Sam Ananias"}</span>
        </a>
        <div class="flex items-center gap-1">
          <ThemeToggle id="theme-toggle-mobile" />
          <button
            id="menu-open"
            type="button"
            aria-expanded="false"
            aria-controls="mobile-menu"
            aria-label="Open navigation menu"
            class="text-text hover:bg-surface-subtle focus-visible:ring-focus flex size-11 items-center justify-center rounded-md outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
          >
            <Menu class="size-5" stroke-width={1.6} />
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Overlay Menu (< lg) -->
    <div
      id="mobile-menu"
      role="dialog"
      aria-modal="true"
      aria-label="Navigation menu"
      class="bg-bg animate-reveal fixed inset-0 z-[60] hidden lg:hidden"
    >
      <div
        class="border-border-custom border-b-hatch flex h-[52px] items-center justify-between px-4"
      >
        <a href="/" class="font-display flex items-center gap-2.5 font-bold">
          <Logo class="size-7" />
          <span class="text-sm">{siteConfig?.name ?? "Sam Ananias"}</span>
        </a>
        <button
          id="menu-close"
          type="button"
          aria-label="Close navigation menu"
          class="text-text hover:bg-surface-subtle focus-visible:ring-focus flex size-11 items-center justify-center rounded-md outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
        >
          <X class="size-5" stroke-width={1.6} />
        </button>
      </div>
      <nav aria-label="Mobile navigation" class="flex flex-col gap-1 px-4 py-6">
        {
          visibleLinks.map((link, index) => {
            const active = isCurrent(link.href);
            const piece = pieceByHref[link.href];
            return (
              <a
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noopener noreferrer" : undefined}
                style={`--i: ${index}; animation-delay: calc(var(--i) * 30ms);`}
                class={`mobile-nav-link animate-reveal flex items-center gap-3 rounded-md px-3 py-3 font-mono text-base transition-colors duration-150 ${
                  active ? "text-text font-semibold" : "text-text-muted hover:text-text font-medium"
                }`}
                aria-current={active ? "page" : undefined}
              >
                {piece ? (
                  <ChessIcons piece={piece} class="size-[18px]" />
                ) : (
                  <span class="w-[18px]" aria-hidden="true" />
                )}
                <span>{link.label}</span>
              </a>
            );
          })
        }
      </nav>
    </div>

    <!-- Desktop Sidebar (≥ lg) -->
    <aside
      class="border-border-custom bg-surface border-r-structural fixed inset-y-0 left-0 z-50 hidden w-56 flex-col overflow-hidden px-7 py-6 lg:flex"
    >
      <!-- Fixed Header Zone -->
      <div class="mb-6 shrink-0">
        <a
          href="/"
          class="text-h4 font-display hover:text-primary duration-fast flex items-center gap-3 font-bold transition-colors"
        >
          <Logo class="size-8" />
          <span>{siteConfig?.name ?? "Sam Ananias"}</span>
        </a>
      </div>

      <!-- Main Navigation Sidebar Landmark -->
      <nav aria-label="Main navigation" class="flex min-h-0 flex-1 flex-col">
        <!-- Primary Scrollable Navigation Zone (Home -> Lab / Work & Writing) -->
        <div class="nav-scrollbar flex min-h-0 flex-1 flex-col gap-3 overflow-y-auto pr-1">
          {
            groupHrefs.slice(0, 2).map((hrefs, groupIndex) => (
              <div class="flex flex-col gap-1.5">
                {groupIndex === 1 && <DividerChessboard class="my-1.5 opacity-70" />}
                <span class="text-text-muted short:hidden hidden px-1 py-0.5 font-mono text-[10px] font-semibold tracking-wider uppercase select-none lg:block">
                  {groupLabels[groupIndex]}
                </span>
                <ul class="flex flex-col gap-1.5">
                  {hrefs.map((href) => {
                    const link = linkByHref.get(href);
                    if (!link) return null;
                    const active = isCurrent(link.href);
                    const piece = pieceByHref[href];
                    return (
                      <li>
                        <a
                          href={link.href}
                          target={link.external ? "_blank" : undefined}
                          rel={link.external ? "noopener noreferrer" : undefined}
                          class={`group focus-visible:ring-focus relative flex min-h-[36px] items-center gap-2.5 rounded-sm py-1 pr-2 pl-6 font-mono text-[13px] tracking-wide transition-colors duration-150 outline-none focus-visible:ring-2 focus-visible:ring-offset-2 ${
                            active
                              ? "text-text font-semibold"
                              : "text-text-muted hover:text-text font-medium"
                          }`}
                          aria-current={active ? "page" : undefined}
                        >
                          {active && (
                            <span
                              class="absolute top-1/2 left-0 size-3 -translate-y-1/2 [&>svg]:size-full"
                              aria-hidden="true"
                              set:html={navIndicator}
                            />
                          )}
                          {piece ? (
                            <ChessIcons
                              piece={piece}
                              class="size-[15px] transition-transform duration-150 group-hover:translate-x-px motion-reduce:transform-none"
                            />
                          ) : (
                            <span class="w-[15px]" aria-hidden="true" />
                          )}
                          <span>{link.label}</span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            ))
          }
        </div>

        <!-- Fixed Bottom Utility & Footer Zone (Meta links, ThemeToggle, Footer) -->
        <div class="mt-auto shrink-0 pt-2">
          <div class="bg-border-custom mb-3 h-[var(--stroke-hatch)] w-full" aria-hidden="true">
          </div>
          {
            groupHrefs.slice(2).map((hrefs, groupOffset) => {
              const groupIndex = 2 + groupOffset;
              return (
                <div class="mb-2 flex flex-col gap-1.5">
                  <span class="text-text-muted short:hidden hidden px-1 py-0.5 font-mono text-[10px] font-semibold tracking-wider uppercase select-none lg:block">
                    {groupLabels[groupIndex]}
                  </span>
                  <ul class="flex flex-col gap-1.5">
                    {hrefs.map((href) => {
                      const link = linkByHref.get(href);
                      if (!link) return null;
                      const active = isCurrent(link.href);
                      const piece = pieceByHref[href];
                      return (
                        <li>
                          <a
                            href={link.href}
                            target={link.external ? "_blank" : undefined}
                            rel={link.external ? "noopener noreferrer" : undefined}
                            class={`group focus-visible:ring-focus relative flex min-h-[36px] items-center gap-2.5 rounded-sm py-1 pr-2 pl-6 font-mono text-[13px] tracking-wide transition-colors duration-150 outline-none focus-visible:ring-2 focus-visible:ring-offset-2 ${
                              active
                                ? "text-text font-semibold"
                                : "text-text-muted hover:text-text font-medium"
                            }`}
                            aria-current={active ? "page" : undefined}
                          >
                            {active && (
                              <span
                                class="absolute top-1/2 left-0 size-3 -translate-y-1/2 [&>svg]:size-full"
                                aria-hidden="true"
                                set:html={navIndicator}
                              />
                            )}
                            {piece ? (
                              <ChessIcons
                                piece={piece}
                                class="size-[15px] transition-transform duration-150 group-hover:translate-x-px motion-reduce:transform-none"
                              />
                            ) : (
                              <span class="w-[15px]" aria-hidden="true" />
                            )}
                            <span>{link.label}</span>
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              );
            })
          }

          <div
            class="pointer-events-none my-2 flex justify-center opacity-20 select-none"
            aria-hidden="true"
          >
            <span class="size-8 [&>svg]:size-full" set:html={knightMarker} />
          </div>
          <div class="bg-border-custom mb-3 h-[var(--stroke-hatch)] w-full" aria-hidden="true">
          </div>
          <ThemeToggle />
          <p class="text-caption text-text-muted mt-2 font-mono">
            &copy; {new Date().getFullYear()} · v1.0.0
          </p>
        </div>
      </nav>
    </aside>

    <!-- Content Column (offset by sidebar on desktop) -->
    <div class="relative z-1 flex min-h-screen flex-col lg:pl-56">
      <main
        id="main-content"
        class="mx-auto w-full max-w-7xl flex-grow px-6 py-8 focus:outline-none md:px-8"
        tabindex="-1"
      >
        <slot />
      </main>

      <!-- Global Footer -->
      <footer class="border-border-custom bg-surface mt-auto border-t px-6 py-6 md:px-8">
        <div
          class="text-small text-text-muted mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 md:flex-row"
        >
          <p>
            &copy; {new Date().getFullYear()}
            {siteConfig?.name ?? "Sam Ananias"}. All rights reserved.
          </p>
          <p class="text-caption font-mono">Official source of truth · Version 1.0.0</p>
        </div>
      </footer>
    </div>

    <!-- Mobile menu: open/close, focus trap, scroll lock (WoodcutTheme.md §5.6 / §5.8) -->
    <script is:inline>
      (function () {
        const overlay = document.getElementById("mobile-menu");
        const openBtn = document.getElementById("menu-open");
        const closeBtn = document.getElementById("menu-close");
        if (!overlay || !openBtn || !closeBtn) return;

        const FOCUSABLE = "a[href], button:not([disabled])";

        function openMenu() {
          overlay.classList.remove("hidden");
          openBtn.setAttribute("aria-expanded", "true");
          document.body.style.overflow = "hidden";
          closeBtn.focus();
        }

        function closeMenu() {
          if (overlay.classList.contains("hidden")) return;

          const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          if (reduceMotion) {
            overlay.classList.add("hidden");
            openBtn.setAttribute("aria-expanded", "false");
            document.body.style.overflow = "";
            openBtn.focus();
            return;
          }

          overlay.classList.add("is-closing");
          setTimeout(function () {
            overlay.classList.remove("is-closing");
            overlay.classList.add("hidden");
            openBtn.setAttribute("aria-expanded", "false");
            document.body.style.overflow = "";
            openBtn.focus();
          }, 200);
        }

        openBtn.addEventListener("click", openMenu);
        closeBtn.addEventListener("click", closeMenu);

        overlay.addEventListener("keydown", function (event) {
          if (event.key === "Escape") {
            closeMenu();
            return;
          }
          if (event.key === "Tab") {
            const focusable = Array.prototype.slice.call(overlay.querySelectorAll(FOCUSABLE));
            if (focusable.length === 0) return;
            const first = focusable[0];
            const last = focusable[focusable.length - 1];
            if (event.shiftKey && document.activeElement === first) {
              event.preventDefault();
              last.focus();
            } else if (!event.shiftKey && document.activeElement === last) {
              event.preventDefault();
              first.focus();
            }
          }
        });

        Array.prototype.slice.call(overlay.querySelectorAll("a[href]")).forEach(function (anchor) {
          anchor.addEventListener("click", closeMenu);
        });
      })();
    </script>
  </body>
</html>
