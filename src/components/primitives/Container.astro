---
interface Props {
  width?: "default" | "wide" | "prose";
  class?: string;
  [key: string]: unknown;
}

const { width = "default", class: className = "", ...rest } = Astro.props;

const widthClasses = {
  default: "max-w-[1200px]",
  wide: "max-w-[1440px]",
  prose: "max-w-[68ch]",
};

const classes = ["mx-auto w-full px-4 sm:px-6 md:px-8", widthClasses[width], className]
  .filter(Boolean)
  .join(" ");
---

<div class={classes} {...rest}>
  <slot />
</div>
