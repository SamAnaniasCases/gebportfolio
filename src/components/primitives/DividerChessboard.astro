---
/**
 * Chessboard strip divider (WoodcutTheme.md §3.3).
 * Eight alternating ink-filled / outlined squares centred on a pair of
 * 1.3px hatch rules. Used between major page sections. Purely decorative —
 * hidden from assistive technology.
 */
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;

const classes = ["flex items-center gap-4", className].filter(Boolean).join(" ");
const squares = Array.from({ length: 8 });
---

<div aria-hidden="true" class={classes}>
  <span class="bg-border-custom h-[var(--stroke-hatch)] flex-1"></span>
  <span class="flex shrink-0">
    {
      squares.map((_, i) => (
        <span class={i % 2 === 0 ? "bg-text size-3" : "border-fine border-border-custom size-3"} />
      ))
    }
  </span>
  <span class="bg-border-custom h-[var(--stroke-hatch)] flex-1"></span>
</div>
