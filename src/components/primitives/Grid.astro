---
interface Props {
  cols?: string | number;
  gap?: string;
  class?: string;
  [key: string]: unknown;
}

const { cols = "4 md:8 lg:12", gap = "4 md:6 lg:8", class: className = "", ...rest } = Astro.props;

// Parse "4 md:8 lg:12" into grid-cols-4 md:grid-cols-8 lg:grid-cols-12
const parseResponsiveCols = (val: string | number) => {
  if (typeof val === "number" || !isNaN(Number(val))) {
    return `grid-cols-${val}`;
  }
  return val
    .split(" ")
    .map((part) => {
      if (part.includes(":")) {
        const [bp, num] = part.split(":");
        return `${bp}:grid-cols-${num}`;
      }
      return `grid-cols-${part}`;
    })
    .join(" ");
};

// Parse "4 md:6 lg:8" into gap-4 md:gap-6 lg:gap-8
const parseResponsiveGap = (val: string) => {
  return val
    .split(" ")
    .map((part) => {
      if (part.includes(":")) {
        const [bp, num] = part.split(":");
        return `${bp}:gap-${num}`;
      }
      return `gap-${part}`;
    })
    .join(" ");
};

const classes = ["grid", parseResponsiveCols(cols), parseResponsiveGap(gap), className]
  .filter(Boolean)
  .join(" ");
---

<div class={classes} {...rest}>
  <slot />
</div>
