---
import sunSvg from "../../assets/theme-icons/sun.svg?raw";
import moonSvg from "../../assets/theme-icons/moon.svg?raw";
import Button from "../primitives/Button.astro";

interface Props {
  /** Unique id — the layout renders two toggles (sidebar + mobile bar). */
  id?: string;
  class?: string;
  [key: string]: unknown;
}

const { id = "theme-toggle", class: className = "", ...rest } = Astro.props;
---

<Button
  id={id}
  variant="ghost"
  size="sm"
  class:list={[
    "theme-toggle group h-11 w-11 rounded-full p-0 transition-transform select-none active:scale-[0.92]",
    className,
  ]}
  aria-label="Toggle theme mode"
  {...rest}
>
  <!-- Moon icon visible in light mode -->
  <span class="flex items-center justify-center dark:hidden">
    <span
      class="size-5 transition-transform duration-300 group-hover:rotate-12 [&>svg]:size-full"
      set:html={moonSvg}
    />
  </span>

  <!-- Sun icon visible in dark mode -->
  <span class="hidden items-center justify-center dark:flex">
    <span
      class="size-5 transition-transform duration-300 group-hover:rotate-45 [&>svg]:size-full"
      set:html={sunSvg}
    />
  </span>
</Button>

<script>
  const handleToggle = () => {
    const isDark = document.documentElement.classList.toggle("dark");
    if (typeof localStorage !== "undefined") {
      localStorage.setItem("theme", isDark ? "dark" : "light");
    }
  };

  // Wire every toggle instance on the page (sidebar + mobile top bar).
  const setupToggles = () => {
    document.querySelectorAll(".theme-toggle").forEach((btn) => {
      btn.removeEventListener("click", handleToggle);
      btn.addEventListener("click", handleToggle);
    });
  };

  // Setup on page load
  setupToggles();

  // Support View Transitions if added later
  document.addEventListener("astro:after-swap", setupToggles);
</script>
