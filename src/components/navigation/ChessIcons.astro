---
import bishop from "../../assets/chess-nav/bishop.svg?raw";
import king from "../../assets/chess-nav/king.svg?raw";
import knight from "../../assets/chess-nav/knight.svg?raw";
import pawn from "../../assets/chess-nav/pawn.svg?raw";
import queen from "../../assets/chess-nav/queen.svg?raw";
import rook from "../../assets/chess-nav/rook.svg?raw";

interface Props {
  piece: "king" | "knight" | "rook" | "bishop" | "pawn" | "queen";
  class?: string;
}

const { piece, class: className = "" } = Astro.props;

const svgMap: Record<Props["piece"], string> = {
  bishop,
  king,
  knight,
  pawn,
  queen,
  rook,
};

const svgContent = svgMap[piece];
---

<span
  class={`chess-piece-icon inline-flex items-center justify-center select-none align-middle [&>svg]:size-full ${className}`}
  aria-hidden="true"
  set:html={svgContent}
/>

<style is:global>
  .chess-piece-icon svg {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    display: block;
    object-fit: contain;
  }
</style>
