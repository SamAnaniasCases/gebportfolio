---
import Container from "../primitives/Container.astro";
import LinkButton from "../primitives/LinkButton.astro";
import InteractiveAvatar from "../primitives/InteractiveAvatar.astro";
import { getEntry } from "astro:content";

const siteConfigEntry = await getEntry("site", "site-config");
const siteConfig = siteConfigEntry?.data;

const name = siteConfig?.name || "Sam Ananias Cases";
const headline = siteConfig?.headline || "Bachelor of Industrial Technology (Computer)";
const location = siteConfig?.location || "Cebu, Philippines";
---

<section class="relative overflow-hidden pt-6 pb-12 md:pt-8 md:pb-16 lg:pt-10 lg:pb-20">
  <Container width="default" class="animate-reveal">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-12">
      <!-- Hero Text Content (Col 1-7) -->
      <div class="space-y-6 lg:col-span-7">
        <!-- Eyebrow Location & Status Badge -->
        <div
          class="border-ink/20 bg-surface text-caption text-muted inline-flex items-center gap-2 rounded-full border px-3 py-1.5 font-mono shadow-sm"
        >
          <span class="h-2 w-2 animate-pulse rounded-full bg-emerald-500"></span>
          <span>{location} · {headline}</span>
        </div>

        <!-- Main Title & Name -->
        <div class="space-y-3">
          <h1
            class="text-display font-display text-text leading-none font-extrabold tracking-tight"
          >
            {name}
          </h1>
          <p class="font-hand text-h4 text-primary block origin-left -rotate-1">
            think in systems, move like a knight
          </p>
        </div>

        <!-- Subheadline & Stance -->
        <p class="text-body-large text-text-muted max-w-2xl leading-relaxed">
          Industrial Technology student and software builder. I design web applications using clean
          architecture specifications, rigorous automated verification, and AI as an interactive
          development partner.
        </p>

        <!-- CTA Action Buttons -->
        <div class="flex flex-wrap gap-4 pt-2">
          <LinkButton href="/projects" variant="primary" size="lg">
            Explore Case Studies →
          </LinkButton>
          <LinkButton href="/docs/plans/" variant="secondary" size="lg">
            Architecture Specs
          </LinkButton>
        </div>
      </div>

      <!-- Hero Avatar Element (Col 8-12) -->
      <div class="flex justify-center lg:col-span-5 lg:justify-end">
        <InteractiveAvatar size="lg" />
      </div>
    </div>
  </Container>
</section>
