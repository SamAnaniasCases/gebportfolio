---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/primitives/Container.astro";
import Grid from "../components/primitives/Grid.astro";
import LinkButton from "../components/primitives/LinkButton.astro";
import Card from "../components/primitives/Card.astro";
import DividerChessboard from "../components/primitives/DividerChessboard.astro";
import { getCollection } from "astro:content";

// Fetch featured projects
const projects = await getCollection("projects");
const featuredProjects = projects.filter((p) => p.data.featured).slice(0, 3);

// Fetch recent experience
const experiences = await getCollection("experience");
const recentExperiences = experiences
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
  .slice(0, 2);
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 lg:py-32">
    <Container width="default" class="animate-reveal space-y-8">
      <div class="max-w-3xl space-y-6">
        <h1 class="text-display font-display text-text leading-tight font-extrabold tracking-tight">
          Designing fault-tolerant <span class="text-primary">systems</span> for scale.
        </h1>
        <!-- Gochi Hand catchphrase — the "Scrawl" voice (WoodcutTheme.md §4.1) -->
        <p class="font-hand text-h4 text-primary inline-block origin-left -rotate-1">
          think in systems, move like a knight
        </p>
        <p class="text-body-large text-text-muted leading-relaxed">
          I am a systems engineer and software architect specializing in low-latency distributed
          telemetry platforms, container bin-packing optimization, and custom developer runtimes.
        </p>
      </div>
      <div class="flex flex-wrap gap-4 pt-4">
        <LinkButton href="/projects" variant="primary" size="lg"> View Cases Study </LinkButton>
        <LinkButton href="/contact" variant="secondary" size="lg"> Get in Touch </LinkButton>
      </div>
    </Container>
  </section>

  <!-- Featured Projects -->
  <section class="py-16 lg:py-24">
    <Container width="default" class="space-y-12">
      <DividerChessboard />
      <div class="flex flex-col justify-between gap-4 md:flex-row md:items-end">
        <div class="space-y-2">
          <h2 class="text-h2 font-display text-text font-bold tracking-tight">
            Featured Case Studies
          </h2>
          <p class="text-body text-text-muted">
            High-performance solutions designed and deployed in production environments.
          </p>
        </div>
        <div>
          <LinkButton href="/projects" variant="ghost" class="text-primary font-semibold">
            See all work →
          </LinkButton>
        </div>
      </div>

      <Grid cols="1 md:2 lg:3" gap="8">
        {
          featuredProjects.map((project) => (
            <Card href={`/projects/${project.id}`}>
              <span slot="eyebrow" class="text-caption tracking-wide uppercase">
                {project.data.dates}
              </span>
              <span slot="title">{project.data.title}</span>
              <p slot="summary">{project.data.summary}</p>
              {project.data.tags.slice(0, 3).map((tag) => (
                <span
                  slot="metadata"
                  class="bg-surface-subtle border-border-custom text-caption text-text-muted rounded border px-2 py-0.5"
                >
                  {tag}
                </span>
              ))}
            </Card>
          ))
        }
      </Grid>
    </Container>
  </section>

  <!-- Recent Work Experience Timeline preview -->
  <section class="py-16 lg:py-24">
    <Container width="default" class="space-y-12">
      <DividerChessboard />
      <div class="flex flex-col justify-between gap-4 md:flex-row md:items-end">
        <div class="space-y-2">
          <h2 class="text-h2 font-display text-text font-bold tracking-tight">
            Recent Work History
          </h2>
          <p class="text-body text-text-muted">
            A summary of my engineering impact at global technology firms.
          </p>
        </div>
        <div>
          <LinkButton href="/experience" variant="ghost" class="text-primary font-semibold">
            Full career timeline →
          </LinkButton>
        </div>
      </div>

      <div class="space-y-8">
        {
          recentExperiences.map((exp) => (
            <div class="border-border-custom bg-surface duration-normal rounded-xl border p-6 transition-all hover:shadow-sm">
              <div class="flex flex-col justify-between gap-2 sm:flex-row sm:items-start">
                <div>
                  <h3 class="text-h4 font-display text-text font-bold">{exp.data.role}</h3>
                  <p class="text-body text-primary font-semibold">{exp.data.organization}</p>
                </div>
                <div class="text-small text-text-muted bg-surface-subtle border-border-custom self-start rounded-full border px-3 py-1 font-medium">
                  {exp.data.start} — {exp.data.end || "Present"}
                </div>
              </div>
              <p class="text-body text-text-muted mt-4 leading-relaxed">{exp.data.summary}</p>
            </div>
          ))
        }
      </div>
    </Container>
  </section>
</BaseLayout>
