---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Sam Ananias - Portfolio Home">
  <div class="animate-reveal max-w-2xl space-y-6 py-12">
    <h1 class="text-h1 font-display leading-tight font-bold tracking-tight">
      Architecture, Design & Engineering
    </h1>
    <p class="text-body-large text-text-muted leading-relaxed">
      Welcome to the professional portfolio and handbook of Sam Ananias. Built for speed,
      accessibility, and longevity.
    </p>
    <div class="pt-4">
      <a
        href="/about"
        class="bg-primary hover:bg-primary-hover duration-fast focus:outline-focus inline-flex items-center justify-center rounded-md px-6 py-3 font-medium text-white transition-colors focus:outline focus:outline-2 focus:outline-offset-2"
      >
        Read the Handbook
      </a>
    </div>
  </div>
</BaseLayout>
