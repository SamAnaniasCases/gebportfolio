---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/primitives/Container.astro";
import Grid from "../../components/primitives/Grid.astro";
import Card from "../../components/primitives/Card.astro";
import { getCollection } from "astro:content";

// Retrieve all projects
const projects = await getCollection("projects");
---

<BaseLayout title="My Projects">
  <Container width="default" class="animate-reveal space-y-12 py-12">
    <!-- Header -->
    <header class="border-border-custom space-y-3 border-b pb-6">
      <h1 class="text-h1 font-display text-text font-bold tracking-tight">
        Case Studies & Projects
      </h1>
      <p class="text-body-large text-text-muted max-w-2xl leading-relaxed">
        A catalog of distributed telemetry nodes, container optimization libraries, and cloud
        schedulers.
      </p>
    </header>

    <!-- Interactive Filters -->
    <div class="flex flex-wrap gap-2" id="filter-container">
      <button
        data-filter="all"
        class="text-small duration-fast bg-primary cursor-pointer rounded-full px-4 py-1.5 font-medium text-white shadow-sm transition-all"
      >
        All Projects
      </button>
      <button
        data-filter="active"
        class="text-small duration-fast bg-surface-subtle border-border-custom text-text-muted hover:text-text cursor-pointer rounded-full border px-4 py-1.5 font-medium transition-all"
      >
        Active
      </button>
      <button
        data-filter="completed"
        class="text-small duration-fast bg-surface-subtle border-border-custom text-text-muted hover:text-text cursor-pointer rounded-full border px-4 py-1.5 font-medium transition-all"
      >
        Completed
      </button>
      <button
        data-filter="planning"
        class="text-small duration-fast bg-surface-subtle border-border-custom text-text-muted hover:text-text cursor-pointer rounded-full border px-4 py-1.5 font-medium transition-all"
      >
        Planning
      </button>
    </div>

    <!-- Projects Grid -->
    <Grid cols="1 md:2 lg:3" gap="8" id="projects-grid">
      {
        projects.map((project) => (
          <div data-project-status={project.data.status} class="duration-normal transition-all">
            <Card href={`/projects/${project.id}`}>
              <span
                slot="eyebrow"
                class="text-caption flex items-center justify-between font-mono tracking-wider uppercase"
              >
                <span>{project.data.dates}</span>
                <span
                  class={`rounded-full border px-2 py-0.5 text-[10px] font-semibold uppercase ${
                    project.data.status === "completed"
                      ? "border-green-500/20 bg-green-500/10 text-green-600 dark:text-green-400"
                      : project.data.status === "active"
                        ? "border-blue-500/20 bg-blue-500/10 text-blue-600 dark:text-blue-400"
                        : "border-amber-500/20 bg-amber-500/10 text-amber-600 dark:text-amber-400"
                  }`}
                >
                  {project.data.status}
                </span>
              </span>
              <span slot="title">{project.data.title}</span>
              <p slot="summary">{project.data.summary}</p>
              {project.data.tags.map((tag) => (
                <span
                  slot="metadata"
                  class="bg-surface-subtle border-border-custom text-caption text-text-muted rounded border px-2 py-0.5 font-medium"
                >
                  {tag}
                </span>
              ))}
            </Card>
          </div>
        ))
      }
    </Grid>
  </Container>

  <!-- Client-side script for lightweight filtering -->
  <script is:inline>
    const buttons = document.querySelectorAll("[data-filter]");
    const cards = document.querySelectorAll("[data-project-status]");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.getAttribute("data-filter");

        // Toggle active button style
        buttons.forEach((b) => {
          b.className =
            "text-small rounded-full px-4 py-1.5 font-medium transition-all duration-fast bg-surface-subtle border-border-custom text-text-muted border hover:text-text cursor-pointer";
        });
        btn.className =
          "text-small rounded-full px-4 py-1.5 font-medium transition-all duration-fast bg-primary text-white cursor-pointer shadow-sm";

        // Filter cards in grid
        cards.forEach((card) => {
          const status = card.getAttribute("data-project-status");
          if (filter === "all" || status === filter) {
            card.classList.remove("hidden");
          } else {
            card.classList.add("hidden");
          }
        });
      });
    });
  </script>
</BaseLayout>
