---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/primitives/Container.astro";
import Grid from "../../components/primitives/Grid.astro";
import Card from "../../components/primitives/Card.astro";
import { getCollection } from "astro:content";

// Fetch posts (filtering out drafts in production/checks)
const allPosts = await getCollection("posts");
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime());

// Collect all unique tags for filter tabs
const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags ?? [])));
---

<BaseLayout title="Writing">
  <Container width="default" class="animate-reveal space-y-12 py-12">
    <!-- Header -->
    <header class="border-border-custom space-y-3 border-b pb-6">
      <h1 class="text-h1 font-display text-text font-bold tracking-tight">
        Technical Writing & Articles
      </h1>
      <p class="text-body-large text-text-muted max-w-2xl leading-relaxed">
        Deep dives on consensus systems, web engines architecture, and developer productivity
        invariants.
      </p>
    </header>

    <!-- Tag Filter Controls -->
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-2" id="tag-filters">
          <button
            data-tag="all"
            class="text-small duration-fast bg-primary cursor-pointer rounded-full px-4 py-1.5 font-medium text-white shadow-sm transition-all"
          >
            All Topics
          </button>
          {tags.map((tag) => (
            <button
              data-tag={tag}
              class="text-small duration-fast bg-surface-subtle border-border-custom text-text-muted hover:text-text cursor-pointer rounded-full border px-4 py-1.5 font-medium transition-all"
            >
              {tag}
            </button>
          ))}
        </div>
      )
    }

    <!-- Posts Listing Grid -->
    <Grid cols="1 md:2" gap="8" id="posts-grid">
      {
        posts.map((post) => (
          <div
            data-post-tags={post.data.tags ? post.data.tags.join(",") : ""}
            class="duration-normal transition-all"
          >
            <Card href={`/posts/${post.id}`}>
              <span slot="eyebrow" class="text-caption font-mono tracking-wider uppercase">
                {post.data.publishedDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </span>
              <span slot="title">{post.data.title}</span>
              <p slot="summary">{post.data.excerpt}</p>
              {post.data.tags &&
                post.data.tags.map((tag) => (
                  <span
                    slot="metadata"
                    class="bg-surface-subtle border-border-custom text-caption text-text-muted rounded border px-2 py-0.5 font-medium"
                  >
                    {tag}
                  </span>
                ))}
            </Card>
          </div>
        ))
      }
    </Grid>
  </Container>

  <!-- Client-side filter script -->
  <script is:inline>
    const buttons = document.querySelectorAll("[data-tag]");
    const cards = document.querySelectorAll("[data-post-tags]");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const selectedTag = btn.getAttribute("data-tag");

        // Toggle active button styling
        buttons.forEach((b) => {
          b.className =
            "text-small rounded-full px-4 py-1.5 font-medium transition-all duration-fast bg-surface-subtle border-border-custom text-text-muted border hover:text-text cursor-pointer";
        });
        btn.className =
          "text-small rounded-full px-4 py-1.5 font-medium transition-all duration-fast bg-primary text-white cursor-pointer shadow-sm";

        // Filter cards
        cards.forEach((card) => {
          const tagsStr = card.getAttribute("data-post-tags") || "";
          const cardTags = tagsStr.split(",").filter(Boolean);

          if (selectedTag === "all" || cardTags.includes(selectedTag)) {
            card.classList.remove("hidden");
          } else {
            card.classList.add("hidden");
          }
        });
      });
    });
  </script>
</BaseLayout>
